			<Import><![CDATA[import java.awt.Color;]]></Import>
			<StartupCode><![CDATA[modelStartTime = System.currentTimeMillis();

traceln("╔════════════════════════════════════════╗");
traceln("║   DIGITAL TWIN - HISTORICAL MODE       ║");
traceln("╚════════════════════════════════════════╝");
traceln("");

// Load historical data from database
loadHistoricalData();

// Process first 3 rows to populate initial display
if (historicalRows != null && historicalRows.size() > 0) {
    traceln("[STARTUP] Populating initial data...");
    for (int i = 0; i < 3; i++) {
        processHistoricalRow();
    }
    traceln("[STARTUP] ✅ Historical replay active");
    traceln("[STARTUP] Processing " + historicalRows.size() + " database rows");
    traceln("");
}]]></StartupCode>
