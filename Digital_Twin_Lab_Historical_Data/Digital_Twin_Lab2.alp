			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Color]]></ReturnType>
					<Id>1771906742986</Id>
					<Name><![CDATA[getColorForTemp]]></Name>
					<X>430</X><Y>620</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[temp]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Body><![CDATA[  if (temp > 100.0) return Color.RED;
  else if (temp > 90.0) return Color.ORANGE;
  else if (temp < 65.0 && temp > 0) return Color.YELLOW;
  else if (temp > 0) return Color.GREEN;
  return Color.GRAY;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Color]]></ReturnType>
					<Id>1771906781607</Id>
					<Name><![CDATA[getColorForSpeed]]></Name>
					<X>100</X><Y>620</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[rpm]]></Name>
						<Type><![CDATA[int]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[status]]></Name>
						<Type><![CDATA[String]]></Type>
					</Parameter>
					<Body><![CDATA[  if ("STOPPED".equals(status) || rpm == 0) return Color.RED;
  else if (rpm > 3200) return Color.ORANGE;
  else if (rpm > 0) return Color.GREEN;
  return Color.GRAY;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1771906823989</Id>
					<Name><![CDATA[processHistoricalRow]]></Name>
					<X>750</X><Y>620</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[// Debug: Show that function is being called
if (currentRowIndex == 0) {
    traceln("[REPLAY] Starting historical data replay...");
}

// Check if data is loaded
if (historicalRows == null) {
    traceln("[ERROR] historicalRows is NULL. Did loadHistoricalData() run?");
    return;
}

// Check if we've reached the end
if (currentRowIndex >= historicalRows.size()) {
    if (currentRowIndex == historicalRows.size()) {
        traceln("[REPLAY] ✅ Reached end of historical data.");
        traceln("[REPLAY] Processed " + currentRowIndex + " rows total.");
    }
    currentRowIndex = 0;
    return;
}

try {
    Tuple row = historicalRows.get(currentRowIndex);
    Date timestamp = row.get(sensor_log_db.timestamp);
    String machineId = row.get(sensor_log_db.machine_id);
    double temperature = row.get(sensor_log_db.temperature);
    double vibration = row.get(sensor_log_db.vibration_level);
    String status = row.get(sensor_log_db.status);
    
    messageCount++;
    
    // Route to the correct machine
    if ("M1".equals(machineId)) {
        m1Temperature = temperature;
        m1Vibration = vibration;
        m1Status = status;
        m1Color = getColorForTemp(temperature);
        m1Active = !"Fail".equals(status) && !"STOPPED".equals(status);
        
    } else if ("M2".equals(machineId)) {
        m2Temperature = temperature;
        m2Vibration = vibration;
        m2Status = status;
        m2Color = getColorForTemp(temperature);
        m2Active = !"Fail".equals(status) && !"STOPPED".equals(status);
        
    } else if ("M3".equals(machineId)) {
        m3Temperature = temperature;
        m3Vibration = vibration;
        m3Status = status;
        m3Color = getColorForTemp(temperature);
        m3Active = !"Fail".equals(status) && !"STOPPED".equals(status);
    }
    
    // Log critical temperatures
    if (temperature > 100.0) {
        traceln(String.format("[ALERT] 🔥 %s CRITICAL TEMP: %.1f C", machineId, temperature));
    }
    
    // Regular logging (every 10th row to avoid spam)
    if (currentRowIndex % 10 == 0 || currentRowIndex < 5) {
        traceln(String.format("[DB #%d] %s | Temp: %.1f C | Status: %s | Active: %s",
            currentRowIndex + 1, machineId, temperature, status,
            "M1".equals(machineId) ? m1Active : "M2".equals(machineId) ? m2Active : m3Active));
    }
    
    currentRowIndex++;
    
} catch (Exception e) {
    traceln("[ERROR] Exception at row " + currentRowIndex + ": " + e.getMessage());
    e.printStackTrace();
    currentRowIndex++;
}]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1771909060922</Id>
					<Name><![CDATA[loadHistoricalData]]></Name>
					<X>600</X><Y>620</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[try {
    traceln("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    traceln("[DATABASE] Step 1: Starting to load data...");
    
    traceln("[DATABASE] Step 2: Executing query on sensor_log_db...");
    historicalRows = selectFrom(sensor_log_db).list();
    
    traceln("[DATABASE] Step 3: Query completed.");
    traceln("[DATABASE] Step 4: historicalRows is " + (historicalRows == null ? "NULL" : "NOT NULL"));
    
    if (historicalRows == null) {
        traceln("[ERROR] ❌ historicalRows is NULL! Database query failed.");
        return;
    }
    
    traceln("[DATABASE] Step 5: Row count = " + historicalRows.size());
    
    if (historicalRows.size() == 0) {
        traceln("[ERROR] ❌ Database table is EMPTY!");
        traceln("[ERROR] Check that sensor_log_db table has 1,000 rows.");
        return;
    }
    
    traceln("[DATABASE] ✅ Loaded " + historicalRows.size() + " rows");
    
    // Get time range
    Tuple firstRow = historicalRows.get(0);
    Tuple lastRow = historicalRows.get(historicalRows.size() - 1);
    
    Date firstTime = firstRow.get(sensor_log_db.timestamp);
    Date lastTime = lastRow.get(sensor_log_db.timestamp);
    
    traceln("[DATABASE] Time range: " + firstTime + " to " + lastTime);
    traceln("[DATABASE] Ready to replay. Press Play to start.");
    traceln("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    
} catch (Exception e) {
    traceln("[DATABASE] ❌❌❌ EXCEPTION CAUGHT ❌❌❌");
    traceln("[DATABASE] Error message: " + e.getMessage());
    traceln("[DATABASE] Error type: " + e.getClass().getName());
    traceln("[DATABASE] Stack trace:");
    e.printStackTrace();
}]]></Body>
				</Function>
